# ExperimentOS backend configuration
# Copy to .env and adjust as needed. All values have sane defaults.

# --- Database ---
# Defaults to a local SQLite file for zero-config dev.
# For PostgreSQL (production), use e.g.:
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/experimentos
DATABASE_URL=sqlite:///./experimentos.db

# --- Auth ---
# Generate a strong secret in production: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-super-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- CORS ---
# Comma-separated list of allowed origins for the frontend.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Optional: real LLM narrative (Anthropic) ---
# If unset, the platform uses its built-in deterministic analyst engine.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
